generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Empresa {
  id       Int      @id @default(autoincrement())
  nome     String
  cnpj     String?  @unique
  ativo    Boolean  @default(true)
  unidades Unidade[]
  @@map("empresas")
}
model Unidade {
  id            Int           @id @default(autoincrement())
  nome          String
  uf            String
  empresaId     Int
  empresa       Empresa       @relation(fields: [empresaId], references: [id])
  colaboradores Colaborador[]
  equipamentos  Equipamento[]
  @@map("unidades")
}
model TipoEquipamento {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  icone        String?
  equipamentos Equipamento[]
  @@map("tipos_equipamento")
}
model Marca {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  equipamentos Equipamento[]
  @@map("marcas")
}
model TipoPosse {
  id           Int           @id @default(autoincrement())
  categoria    String        @unique
  equipamentos Equipamento[]
  @@map("tipos_posse")
}
model Contrato {
  id           Int           @id @default(autoincrement())
  numero       String        @unique
  fornecedor   String?
  dataContrato DateTime
  dataFinal    DateTime
  valor        Decimal?      @db.Decimal(12,2)
  observacoes  String?
  equipamentos Equipamento[]
  @@map("contratos")
}
model Colaborador {
  id               String               @id
  matricula        String?
  nome             String
  cargo            String?
  setor            String?
  unidadeId        Int
  unidade          Unidade              @relation(fields: [unidadeId], references: [id])
  tipoTrabalho     TipoTrabalho
  situacao         SituacaoTrabalho     @default(Trabalhando)
  dataAdmissao     DateTime?
  dataDesligamento DateTime?
  userRede         String?
  email            String?
  ativo            Boolean              @default(true)
  equipamentos     EquipamentoUsuario[]
  licencas         LicencaUsuario[]
  termos           TermoEquipamento[]
  @@map("colaboradores")
}
model Equipamento {
  nserial         String               @id
  dataAtualizacao DateTime?
  status          StatusEquipamento    @default(Ativo)
  patrimonio      String?
  tipoEquipId     Int
  tipoEquip       TipoEquipamento      @relation(fields: [tipoEquipId], references: [id])
  posseId         Int
  posse           TipoPosse            @relation(fields: [posseId], references: [id])
  contratoId      Int?
  contrato        Contrato?            @relation(fields: [contratoId], references: [id])
  marcaId         Int?
  marca           Marca?               @relation(fields: [marcaId], references: [id])
  modelo          String?
  processador     String?
  geracao         String?
  ram             String?
  memoriaDisco    String?
  unidadeId       Int
  unidade         Unidade              @relation(fields: [unidadeId], references: [id])
  observacoes     String?
  ativo           Boolean              @default(true)
  usuarios        EquipamentoUsuario[]
  ocorrencias     Ocorrencia[]
  termosNovo      TermoEquipamento[]   @relation("TermoNovo")
  termosDevolvido TermoEquipamento[]   @relation("TermoDevolvido")
  @@map("equipamentos")
}
model EquipamentoUsuario {
  nserial        String
  colaboradorId  String
  equipamento    Equipamento @relation(fields: [nserial], references: [nserial])
  colaborador    Colaborador @relation(fields: [colaboradorId], references: [id])
  unidadeId      Int
  cargo          String?
  setor          String?
  dataVinculo    DateTime    @default(now())
  dataDesvinculo DateTime?
  principal      Boolean     @default(true)
  @@id([nserial, colaboradorId])
  @@map("equipamento_usuarios")
}
model TipoLicenca {
  id        Int              @id @default(autoincrement())
  nome      String           @unique
  tipo      String
  descricao String?
  custo     Decimal?         @db.Decimal(10,2)
  usuarios  LicencaUsuario[]
  @@map("tipos_licenca")
}
model LicencaUsuario {
  id            Int         @id @default(autoincrement())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id])
  licencaId     Int
  licenca       TipoLicenca @relation(fields: [licencaId], references: [id])
  dataInicio    DateTime    @default(now())
  dataFim       DateTime?
  ativa         Boolean     @default(true)
  @@map("licenca_usuarios")
}
model CategoriaPerfil {
  id            Int     @id @default(autoincrement())
  nome          String  @unique
  processamento String
  ram           String
  memoriaDisco  String
  mobilidade    Boolean
  licencaOffice String
  fabric        Boolean @default(false)
  project       Boolean @default(false)
  powerBi       Boolean @default(false)
  @@map("categorias_perfil")
}
model TermoEquipamento {
  id                   Int          @id @default(autoincrement())
  unidadeId            Int
  colaboradorId        String
  colaborador          Colaborador  @relation(fields: [colaboradorId], references: [id])
  nserialNovo          String?
  equipamentoNovo      Equipamento? @relation("TermoNovo", fields: [nserialNovo], references: [nserial])
  nserialDevolvido     String?
  equipamentoDevolvido Equipamento? @relation("TermoDevolvido", fields: [nserialDevolvido], references: [nserial])
  termoDigitalizado    Boolean      @default(false)
  arquivoUrl           String?
  dataAssinatura       DateTime
  nomeCompleto         String
  criadoEm             DateTime     @default(now())
  @@map("termos_equipamento")
}
model Ocorrencia {
  id          Int         @id @default(autoincrement())
  nserial     String
  equipamento Equipamento @relation(fields: [nserial], references: [nserial])
  tipo        String?
  descricao   String
  dataOcorr   DateTime    @default(now())
  resolvidoEm DateTime?
  @@map("ocorrencias")
}
model AuditLog {
  id            Int       @id @default(autoincrement())
  tabela        String
  registroId    String
  campo         String?
  valorAnterior String?
  valorNovo     String?
  acao          AcaoAudit
  usuarioId     Int
  usuarioNome   String
  ip            String?
  userAgent     String?
  timestamp     DateTime  @default(now())
  @@map("audit_logs")
}
model UsuarioSistema {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  nome         String
  senha        String
  perfil       PerfilAcesso
  empresasIds  Int[]        @default([])
  ativo        Boolean      @default(true)
  ultimoAcesso DateTime?
  criadoEm     DateTime     @default(now())
  @@map("usuarios_sistema")
}
enum TipoTrabalho     { CLT PJ PostoTrabalho Terceiro }
enum SituacaoTrabalho { Trabalhando Afastado Desligado }
enum StatusEquipamento { Ativo Estoque Desativado Baixado EmManutencao FurtadoRoubado }
enum PerfilAcesso     { Administrador GestorTI Tecnico Consultor }
enum AcaoAudit        { CREATE UPDATE DELETE LOGIN LOGOUT SYNC }

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id       Int       @id @default(autoincrement())
  nome     String
  cnpj     String?   @unique
  ativo    Boolean   @default(true)
  unidades Unidade[]

  @@map("empresas")
}

model Unidade {
  id            Int           @id @default(autoincrement())
  nome          String
  uf            String
  empresaId     Int
  empresa       Empresa       @relation(fields: [empresaId], references: [id])
  colaboradores Colaborador[]
  equipamentos  Equipamento[]

  @@map("unidades")
}

model Colaborador {
  id               String             @id
  matricula        String?
  nome             String
  cargo            String?
  setor            String?
  unidadeId        Int
  tipoTrabalho     TipoTrabalho
  situacao         SituacaoTrabalho   @default(Trabalhando)
  dataAdmissao     DateTime?
  dataDesligamento DateTime?
  userRede         String?
  email            String?
  ativo            Boolean            @default(true)
  unidade          Unidade            @relation(fields: [unidadeId], references: [id])
  equipamentos     EquipamentoUsuario[]
  licencas         LicencaUsuario[]
  termos           TermoEquipamento[]

  @@map("colaboradores")
}

model Equipamento {
  nserial         String               @id
  dataAtualizacao DateTime?
  status          StatusEquipamento    @default(Ativo)
  patrimonio      String?
  tipoEquipId     Int
  posseId         Int
  contratoId      Int?
  marcaId         Int?
  modelo          String?
  processador     String?
  geracao         String?
  ram             String?
  memoriaDisco    String?
  unidadeId       Int
  observacoes     String?
  ativo           Boolean              @default(true)
  tipoEquip       TipoEquipamento      @relation(fields: [tipoEquipId], references: [id])
  posse           TipoPosse            @relation(fields: [posseId], references: [id])
  marca           Marca?               @relation(fields: [marcaId], references: [id])
  unidade         Unidade              @relation(fields: [unidadeId], references: [id])
  contrato        Contrato?            @relation(fields: [contratoId], references: [id])
  usuarios        EquipamentoUsuario[]
  ocorrencias     Ocorrencia[]
  termosNovos     TermoEquipamento[]   @relation("TermoNovo")
  termosDevolvidos TermoEquipamento[]  @relation("TermoDev")

  @@map("equipamentos")
}

model TipoEquipamento {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  icone        String?
  equipamentos Equipamento[]

  @@map("tipos_equipamento")
}

model Marca {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  equipamentos Equipamento[]

  @@map("marcas")
}

model TipoPosse {
  id           Int           @id @default(autoincrement())
  categoria    String        @unique
  equipamentos Equipamento[]

  @@map("tipos_posse")
}

model Contrato {
  id           Int           @id @default(autoincrement())
  numero       String        @unique
  fornecedor   String?
  dataContrato DateTime
  dataFinal    DateTime
  valor        Decimal?      @db.Decimal(12, 2)
  observacoes  String?
  equipamentos Equipamento[]

  @@map("contratos")
}

model EquipamentoUsuario {
  nserial        String
  colaboradorId  String
  unidadeId      Int
  cargo          String?
  setor          String?
  dataVinculo    DateTime    @default(now())
  dataDesvinculo DateTime?
  principal      Boolean     @default(true)
  equipamento    Equipamento @relation(fields: [nserial], references: [nserial])
  colaborador    Colaborador @relation(fields: [colaboradorId], references: [id])

  @@id([nserial, colaboradorId])
  @@map("equipamento_usuarios")
}

model TipoLicenca {
  id        Int              @id @default(autoincrement())
  nome      String           @unique
  tipo      String
  descricao String?
  custo     Decimal?         @db.Decimal(10, 2)
  licencas  LicencaUsuario[]

  @@map("tipos_licenca")
}

model LicencaUsuario {
  id            Int         @id @default(autoincrement())
  colaboradorId String
  licencaId     Int
  dataInicio    DateTime    @default(now())
  dataFim       DateTime?
  ativa         Boolean     @default(true)
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id])
  licenca       TipoLicenca @relation(fields: [licencaId], references: [id])

  @@map("licenca_usuarios")
}

model CategoriaPerfil {
  id            Int     @id @default(autoincrement())
  nome          String  @unique
  processamento String
  ram           String
  memoriaDisco  String
  mobilidade    Boolean
  licencaOffice String
  fabric        Boolean @default(false)
  project       Boolean @default(false)
  powerBi       Boolean @default(false)

  @@map("categorias_perfil")
}

model TermoEquipamento {
  id                Int         @id @default(autoincrement())
  unidadeId         Int
  colaboradorId     String
  nserialNovo       String?
  nserialDevolvido  String?
  termoDigitalizado Boolean     @default(false)
  arquivoUrl        String?
  dataAssinatura    DateTime
  nomeCompleto      String
  criadoEm          DateTime    @default(now())
  colaborador       Colaborador @relation(fields: [colaboradorId], references: [id])
  equipamentoNovo   Equipamento? @relation("TermoNovo", fields: [nserialNovo], references: [nserial])
  equipamentoDev    Equipamento? @relation("TermoDev", fields: [nserialDevolvido], references: [nserial])

  @@map("termos_equipamento")
}

model Ocorrencia {
  id          Int         @id @default(autoincrement())
  nserial     String
  tipo        String?
  descricao   String
  dataOcorr   DateTime    @default(now())
  resolvidoEm DateTime?
  equipamento Equipamento @relation(fields: [nserial], references: [nserial])

  @@map("ocorrencias")
}

model AuditLog {
  id            Int       @id @default(autoincrement())
  tabela        String
  registroId    String
  campo         String?
  valorAnterior String?
  valorNovo     String?
  acao          AcaoAudit
  usuarioId     Int
  usuarioNome   String
  ip            String?
  userAgent     String?
  timestamp     DateTime  @default(now())

  @@index([tabela, registroId])
  @@index([usuarioId])
  @@index([timestamp])
  @@map("audit_logs")
}

model UsuarioSistema {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  nome         String
  senha        String
  perfil       PerfilAcesso
  empresasIds  Int[]
  ativo        Boolean      @default(true)
  ultimoAcesso DateTime?
  criadoEm     DateTime     @default(now())

  @@map("usuarios_sistema")
}

enum TipoTrabalho {
  CLT
  PJ
  PostoTrabalho
  Terceiro
}

enum SituacaoTrabalho {
  Trabalhando
  Afastado
  Desligado
}

enum StatusEquipamento {
  Ativo
  Estoque
  Desativado
  Baixado
  EmManutencao
  FurtadoRoubado
}

enum PerfilAcesso {
  Administrador
  GestorTI
  Tecnico
  Consultor
}

enum AcaoAudit {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SYNC
}
